<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Ruby Sinatra Trino Iceberg Log Search</title>
    <link rel="stylesheet" href="/styles.css">
  </head>
  <body>
    <main class="shell">
      <section class="header">
        <div>
          <p class="eyebrow">Trino Iceberg Log Search</p>
          <h1>ログのキーワード検索</h1>
          <p class="note">検索対象日は JST の当日です。条件に一致したログのうち最新50件のみ表示します。</p>
        </div>
      </section>

      <form id="search-form" class="search" method="post" action="/">
        <label>
          <span>TIME From (JST)</span>
          <input type="time" name="time_from" value="<%= h filters["time_from"] %>">
        </label>
        <label>
          <span>TIME To (JST)</span>
          <input type="time" name="time_to" value="<%= h filters["time_to"] %>">
        </label>
        <label>
          <span>LOG</span>
          <select name="log_type">
            <option value="">すべて</option>
            <% log_types.each do |log_type| %>
              <option value="<%= h log_type %>" <%= "selected" if filters["log_type"] == log_type %>><%= h log_type %></option>
            <% end %>
          </select>
        </label>
        <label>
          <span>HOST</span>
          <input
            type="search"
            name="host"
            value="<%= h filters["host"] %>"
            placeholder="例: elastic1, flink1"
            aria-label="Host"
          >
        </label>
        <label>
          <span>PROGRAM</span>
          <input
            type="search"
            name="program"
            value="<%= h filters["program"] %>"
            placeholder="例: sshd, systemd, hdfs"
            aria-label="Program"
          >
        </label>
        <label class="message-filter">
          <span>Message</span>
          <input
            type="search"
            name="message"
            value="<%= h filters["message"] %>"
            placeholder="例: accepted, JournalNodeSyncer"
            aria-label="Message"
            autofocus
          >
        </label>
        <div class="search-actions">
          <a class="reset-link" href="/clear">クリア</a>
          <button type="submit">検索</button>
        </div>
      </form>

      <section id="results" class="results" aria-live="polite">
        <div id="results-summary" class="summary">
          <% if searched %>
            <span><%= logs.length %> 件</span>
            <span>最新50件のみ表示</span>
          <% else %>
            <span>検索を実施してください</span>
          <% end %>
        </div>

        <% if !searched %>
          <p id="results-body" class="empty">検索条件を入力して検索ボタンを押してください。</p>
        <% elsif logs.any? %>
          <div id="results-body" class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th>Time</th>
                  <th>Log</th>
                  <th>Host</th>
                  <th>Program</th>
                  <th>Message</th>
                </tr>
              </thead>
              <tbody>
                <% logs.each do |log| %>
                  <tr>
                    <td><%= h log["display_time"] %></td>
                    <td><span class="log-type log-type-<%= h(log["log_type"] || "unknown") %>"><%= h(log["log_type"] || "unknown") %></span></td>
                    <td><%= h log["host"] %></td>
                    <td><%= h log["program"] %></td>
                    <td><%= h log["msg"] %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% else %>
          <p id="results-body" class="empty">該当するログはありません。</p>
        <% end %>
      </section>
    </main>
    <script src="/search.js"></script>
  </body>
</html>
